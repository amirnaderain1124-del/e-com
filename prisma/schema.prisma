generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ApplicationStatus {
  NEW
  REVIEWING
  APPROVED
  REJECTED
}

model User {
  id                String            @id @default(cuid())
  clerkId           String?           @unique
  email             String            @unique
  name              String?
  role              Role              @default(USER)
  orders            Order[]
  reviews           Review[]
  carts             Cart[]
  wishlist          WishlistItem[]
  shippingAddresses ShippingAddress[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?
  user      User?      @relation(fields: [userId], references: [id])
  sessionId String?
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  variantId String?
  quantity  Int
  price     Int
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  description      String
  details          String[]
  categoryId       String
  category         Category         @relation(fields: [categoryId], references: [id])
  price            Int
  compareAtPrice   Int?
  currency         String           @default("AED")
  images           ProductImage[]
  variants         ProductVariant[]
  reviews          Review[]
  wishlist         WishlistItem[]
  orderItems       OrderItem[]
  inventory        Inventory?
  tags             String[]
  isFeatured       Boolean          @default(false)
  isBestSeller     Boolean          @default(false)
  seoTitle         String?
  seoDescription   String?
  structuredData   Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder Int     @default(0)
}

model ProductVariant {
  id        String      @id @default(cuid())
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String      @unique
  color     String?
  size      String?
  price     Int?
  stock     Int         @default(0)
  inventory Inventory[]
}

model Inventory {
  id        String          @id @default(cuid())
  productId String?         @unique
  product   Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int
  reserved  Int             @default(0)
  lowStock  Int             @default(5)
  location  String          @default("Dubai Fulfillment")
  updatedAt DateTime        @updatedAt
}

model Order {
  id                String           @id @default(cuid())
  userId            String?
  user              User?            @relation(fields: [userId], references: [id])
  email             String
  status            OrderStatus      @default(PENDING)
  currency          String           @default("AED")
  subtotal          Int
  shipping          Int
  discount          Int              @default(0)
  total             Int
  stripeSessionId   String?          @unique
  trackingNumber    String?
  shippingAddressId String?
  shippingAddress   ShippingAddress? @relation(fields: [shippingAddressId], references: [id])
  couponId          String?
  coupon            Coupon?          @relation(fields: [couponId], references: [id])
  items             OrderItem[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  variant   String?
  quantity  Int
  price     Int
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  title     String
  body      String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  percentOff  Int?
  amountOff   Int?
  active      Boolean  @default(true)
  expiresAt   DateTime?
  orders      Order[]
}

model ShippingAddress {
  id          String  @id @default(cuid())
  userId      String?
  user        User?   @relation(fields: [userId], references: [id])
  fullName    String
  phone       String
  line1       String
  line2       String?
  city        String
  emirate     String
  country     String  @default("United Arab Emirates")
  postalCode  String?
  orders      Order[]
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  coverImage  String
  author      String
  published   Boolean  @default(false)
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SponsorshipApplication {
  id             String            @id @default(cuid())
  fullName       String
  email          String
  instagram      String?
  tiktok         String?
  federation     String?
  total          String?
  achievements   String
  proposal       String
  status         ApplicationStatus @default(NEW)
  createdAt      DateTime          @default(now())
}
